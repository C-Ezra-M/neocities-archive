---
import PokemonPl from './PokemonPl.astro';

interface Props {
    /** The Pokémon's English name. */
	name: string;
    /** The card ID on the pokemontcg.io API. */
    card: string;
    /** The proposed Polish name. */
    pl: string;
    /** The style of the Pokémon image. Mostly used to change crop coordinates from the defaults:
     * ```css
     * --offset-left: -85px;
       --offset-top -55px;
        ```
     */
    style: string;
}

const { name, card, pl, style } = Astro.props;
---

<PokemonPl name={name} card={card} pl={pl} style={style}>
    <Fragment slot="etymology"><slot /></Fragment>
    <Fragment slot="notes"></Fragment>
</PokemonPl>