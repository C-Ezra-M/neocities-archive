---
import PokemonPl from './PokemonPl.astro';

interface Props {
    /** The Pokémon's English name. */
	name: string;
    /** The card ID on the pokemontcg.io API. */
    card: string;
    /** The proposed Polish name. */
    pl: string;
    /** The style of the Pokémon image. Mostly used to change crop coordinates from the defaults:
     * ```css
     * --offset-left: -75px;
       --offset-top -50px;
        ```
     */
    style: string;
    /** Base transcription, to be converted into IPA. Used when graphemes don't give off the intended pronunciation. */
    pron?: string;
}

const { name, card, pl, style, pron } = Astro.props;
---

<PokemonPl name={name} card={card} pl={pl} style={style} pron={pron}>
    <Fragment slot="etymology"><slot /></Fragment>
    <Fragment slot="notes"></Fragment>
</PokemonPl>