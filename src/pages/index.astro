---
import Layout from '#layouts/Layout.astro';
import Card from '#components/Card.astro';

import { Image } from 'astro:assets';
import ezraArtwork from '#img/ezra.png';
---

<Layout title="C.Ezra.M's home page">
	<main>
		<h1 class="fs-1">C.Ezra.M</h1>
		<Image
			src={ezraArtwork}
			alt="Ezra"
			width="300"
			height="524"
			class="float-start me-3 mb-3"
		/>
		<p>
			You're on the home page of <dfn>Cody Ezra Marcel</dfn>, the late maturer!
		</p>
		<ul role="list" class="link-card-grid">
			<Card
				href="/pokemon-pl"
				title="Polish Pokémon names"
				body="A list of my own ideas for Polish Pokémon names"
			/>
			<Card
				href="/camps/mud"
				title="Mutually Unhinged Destruction"
				body="An object camp started by C.Ezra.M in 2025, co-hosted by TGiovans and INEI"
			/>
			<Card
				href="/algotriacontathlon"
				title="Algotriacontathlon"
				body="A competition where 32 colors duke it out in 30 events to see who is truly the best!"
			/>
			<Card
				href="/toki-pona"
				title="ijo pi toki pona"
			>Apparently I'm also an aspiring Tokiponist. The page's body content is in <i>toki pona taso</i>.</Card>
		</ul>
	</main>
</Layout>
<style>
	.link-card-grid {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 0;
	}
</style>
